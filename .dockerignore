# Version control
.git/
.gitignore

# Virtual environment
.venv/

# Tests
tests/

# Scripts (not needed at runtime)
scripts/

# Development tools
Makefile

# Local secrets
.env
.env.*

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Linter / type checker caches
.mypy_cache/
.ruff_cache/

# Test cache
.pytest_cache/
htmlcov/
.coverage
.coverage.*

# Build artifacts
*.egg-info/
dist/
build/

# Documentation
AGENTS.md
# README.md is intentionally NOT excluded — pyproject.toml declares it as the
# package readme and the build backend requires it during `pip install`.

# Editor / OS
.DS_Store
*.swp
*.swo
.idea/
.vscode/
